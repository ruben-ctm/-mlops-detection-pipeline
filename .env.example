# Model Configuration
DETECTOR_PATH=yolov8n.pt
DESCRIPTOR_MODEL=openai/clip-vit-base-patch32
CONFIDENCE_THRESHOLD=0.5

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=1

# MLflow Configuration
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=object-detection

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
